{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tallow.local/events/analysis-requested.v1.schema.json",
  "type": "object",
  "required": [
    "ecosystem",
    "package",
    "version",
    "artifact_id",
    "artifact_kind",
    "storage_uri",
    "local_hashes",
    "observed_at"
  ],
  "properties": {
    "ecosystem": {"type": "string"},
    "package": {"type": "string"},
    "version": {"type": "string"},
    "artifact_id": {"type": "string"},
    "artifact_kind": {"type": "string"},
    "storage_uri": {
      "type": "string",
      "minLength": 1,
      "not": {"pattern": "://"}
    },
    "registry_hashes": {"type": "object"},
    "local_hashes": {
      "type": "object",
      "required": ["sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "reason": {"type": "string"},
    "observed_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
