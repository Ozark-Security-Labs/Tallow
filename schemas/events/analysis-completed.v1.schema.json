{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tallow.local/events/analysis-completed.v1.schema.json",
  "type": "object",
  "required": ["job_id", "run_id", "status", "findings_emitted", "completed_at"],
  "properties": {
    "job_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"const": "ok"},
    "analyzer_id": {"type": "string"},
    "analyzer_version": {"type": "string"},
    "ruleset_version": {"type": "string"},
    "findings_emitted": {"type": "integer", "minimum": 0},
    "completed_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
