{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tallow.local/unpack-manifest.schema.json",
  "type": "object",
  "required": ["artifact_id", "policy_version", "entries", "rejected_entries", "totals", "truncated"],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "minLength": 1},
    "entries": {"type": "array", "items": {"$ref": "#/$defs/entry"}},
    "rejected_entries": {"type": "array", "items": {"$ref": "#/$defs/entry"}},
    "totals": {
      "type": "object",
      "required": ["files", "directories", "rejected", "total_bytes", "truncated_by_policy"],
      "properties": {
        "files": {"type": "integer", "minimum": 0},
        "directories": {"type": "integer", "minimum": 0},
        "rejected": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0},
        "truncated_by_policy": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "truncated": {"type": "boolean"}
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["path", "type", "size", "mode"],
      "properties": {
        "path": {"type": "string"},
        "type": {"type": "string"},
        "size": {"type": "integer", "minimum": 0},
        "mode": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "line_count": {"type": "integer", "minimum": 0},
        "rejected_reason": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
